# Dependencies
node_modules/
**/node_modules/

# Compiled output
dist/
**/dist/
*.js.map
*.d.ts

# VS Code extension build artifacts
vscode-extension/out/
vscode-extension/*.vsix
*.vsix

# Runtime session state (generated by the orchestrator)
.goal/sessions/
.goal/sessions/**/

# Orchestrator runtime registries / backups
sessions_registry.json
sessions_registry.json.tmp.*
sessions_registry.json.corrupt.*

# Logs
*.log
npm-debug.log*

# OS / editor cruft
.DS_Store
Thumbs.db
*.tmp
*.bak
.vscode/settings.json

# Test artifacts
test/tmp/
test/**/tmp/
coverage/

# Plans (kilo) - keep plans dir but ignore any local-only notes
.kilo/*
